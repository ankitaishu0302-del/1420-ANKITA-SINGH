<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>PHP Table Example</title>

    <!-- Bootstrap CSS (optional for styling) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-5">

<h2>User Table (Using PHP print)</h2>

<?php
// Sample data (can come from database)
$users = [
    ["id" => 1, "name" => "Rahul", "email" => "rahul@email.com"],
    ["id" => 2, "name" => "Priya", "email" => "priya@email.com"],
    ["id" => 3, "name" => "Amit", "email" => "amit@email.com"]
];

// Start table
print '
<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
        </tr>
    </thead>
    <tbody>
';

// Loop through data
foreach ($users as $user) {
    print '
    <tr>
        <td>'.$user['id'].'</td>
        <td>'.$user['name'].'</td>
        <td>'.$user['email'].'</td>
    </tr>
    ';
}

// End table
print '
    </tbody>
</table>
';
?>

</body>
</html>